// Prisma Schema for GameOver
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String?
  googleId      String?  @unique
  avatarUrl     String?
  securityStamp String   @default(dbgenerated("gen_random_uuid()"))
  salary        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions Transaction[]
  purchases    FuturePurchase[]
  goals        Goal[]
  snapshots    MonthlySnapshot[]
  treeNodes    TreeNode[]
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "income" | "expense"
  category  String   // "essential" | "leisure" | "investment" | "future_purchase"
  name      String
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
}

model FuturePurchase {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  value       Float
  link        String?
  imageUrl    String?
  purchased   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  name        String
  targetValue Float
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MonthlySnapshot {
  id           String   @id @default(cuid())
  userId       String
  month        Int      // 1–12
  year         Int
  totalIncome  Float
  totalExpense Float
  totalSaved   Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
}

model TreeNode {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  imageUrl    String?
  status      String     @default("pending") // "pending" | "in_progress" | "done"
  color       String?    // hex custom color
  date        DateTime?
  parentId    String?
  positionX   Float      @default(0)
  positionY   Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deletedAt   DateTime?

  parent   TreeNode?  @relation("NodeChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children TreeNode[] @relation("NodeChildren")
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
}
